# relayrad environment variables
# Copy to .env and fill in your values: cp .env.example .env

# --- Bind ---
RELAYRAD_HOST=127.0.0.1
RELAYRAD_PORT=4123

# --- Mullvad ---
# Override Mullvad SOCKS host/port (optional)
# RELAYRAD_SOCKS_HOST_OVERRIDE=
# RELAYRAD_SOCKS_PORT_OVERRIDE=

# --- NordVPN ---
# Service credentials (required for NordVPN proxy connections)
# Get them at: https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/service-credentials/
# NORDVPN_USERNAME=
# NORDVPN_PASSWORD=

# Override NordVPN API URL (optional)
# NORDVPN_API_URL=https://api.nordvpn.com/v1/servers?limit=10000
